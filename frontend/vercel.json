{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://systaging.mentto.com.br/apontamentto-api/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
